        <br style="height: 5px" />
        SIND TRAB EMP SERV CONT ASS PER INF PESQ EMP PREST SERV
        <br />
        <br />
    </label>
    <br />
    <br />
    <label class="textonome">
        MURILO ZANELLO MILLEO
        <br style="height: 5px" />
        Tesoureiro
        <br style="height: 5px" />
        FEDERACAO DOS TRABALHADORES EM EMPRESAS ENQUADRADAS NO TERCEIRO GRUPO COMERCIO E EMPREGADOS EM EMPRESAS PRESTADORAS DE SERVICOS DO ESTADO DO PARANA
        <br />
        <br />
    </label>
                                            </td>
                                        </tr>
                                    </table>
                                        <br />
                                        <center>
                                            <label class="textogrupo">
                                                <b>ANEXOS </b>
                                            </label>
                                        </center>
                                                        <label>
                                                            <b>
                                                                <center>
                                                                    <label class="textogrupo">
                                                                        ANEXO I - ATA
                                                                    </label>
                                                                </center>
                                                                <label class="tituloClausula">
                                                                                                                                    </label>
                                                            </b>
                                                        </label>
                                                        <b>
                                                            <label>

                                                            </label>
                                                        </b>
                                                        <br />
                                                        <label class="descricaoClausula" >
