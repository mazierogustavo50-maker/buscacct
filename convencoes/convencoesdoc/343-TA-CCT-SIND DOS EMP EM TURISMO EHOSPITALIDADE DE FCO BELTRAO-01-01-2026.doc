                                            </center>
                                                <label class="tituloClausula">
                                                    <b>
                                                        <br />
                                                        CL&#193;USULA D&#201;CIMA PRIMEIRA - APLICA&#199;&#195;O DO ACORDO
                                                        <br />
                                                                                                                                                                                                                                                                                        
                                                    </b>
                                                </label>
                                                <br />
                                                <label class="descricaoClausula" >
                                                    <p style="text-align: justify;">O presente Acordo Coletivo de Trabalho (ACT) se aplica &agrave; todas as unidades existentes da MITRA, na &aacute;rea da abrang&ecirc;ncia do SINDICATO, com os seguintes CNPJs:&nbsp;75.661.264/0022-10, 75.661.264/0042-63, 75.661.264/0050-73, 75.661.264/0039-68, 75.661.264/0020-58, 75.661.264/0040-00, 75.661.264/0029-96, 75.661.264/0031-00, 75.661.264/0034-53, 75.661.264/0028-05, 75.661.264/0036-15, 75.661.264/0025-62, 75.661.264/0032-91, 75.661.264/0052-35, 75.661.264/0018-33, 75.661.264/0030-20, 75.661.264/0033-72, 75.661.264/0019-14, 75.661.264/0004-38, 75.661.264/0035-34, 75.661.264/0037-04,75.661.264/0055-88, 75.661.264/0057-40, 75.661.264/0056-69, 75.661.264/0059-01, 75.661.264/0054-05.</p>
                                                </label>
                                                <br />
                                    }
