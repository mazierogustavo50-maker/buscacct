                                        <center>
                                            <label class="textogrupo">
                                                <b>ANEXOS </b>
                                            </label>
                                        </center>
                                                        <label>
                                                            <b>
                                                                <center>
                                                                    <label class="textogrupo">
                                                                        ANEXO I - ATA AGE CURITIBA
                                                                    </label>
                                                                </center>
                                                                <label class="tituloClausula">
                                                                                                                                    </label>
                                                            </b>
                                                        </label>
                                                        <b>
                                                            <label>

                                                            </label>
                                                        </b>
                                                        <br />
                                                        <label class="descricaoClausula" >
                                                            <p><span style="text-decoration: underline;"><a href="https://www3.mte.gov.br/sistemas/mediador/imagemAnexo/MR000745_20252025_01_14T08_22_37.pdf" target="_blank">Anexo (PDF)</a><br /></span></p>
                                                        </label>
                                                        <br />
                                                        <label>
                                                            <b>
                                                                <center>
                                                                    <label class="textogrupo">
                                                                        ANEXO II - ATA AGE PONTA GROSSA
                                                                    </label>
                                                                </center>
                                                                <label class="tituloClausula">
                                                                                                                                    </label>
                                                            </b>
                                                        </label>
                                                        <b>
                                                            <label>

                                                            </label>
                                                        </b>
                                                        <br />
                                                        <label class="descricaoClausula" >
                                                            <p><span style="text-decoration: underline;"><a href="https://www3.mte.gov.br/sistemas/mediador/imagemAnexo/MR000745_20252025_01_10T09_57_25.pdf" target="_blank">Anexo (PDF)</a><br /></span></p>
                                                        </label>
                                                        <br />
                                                        <label>
                                                            <b>
                                                                <center>
                                                                    <label class="textogrupo">
                                                                        ANEXO III - ATA AGE CASCAVEL
                                                                    </label>
                                                                </center>
                                                                <label class="tituloClausula">
                                                                                                                                    </label>
                                                            </b>
                                                        </label>
                                                        <b>
                                                            <label>

                                                            </label>
                                                        </b>
