<p align="center"><strong>R$ 2.143,22</strong></p>
</td>
</tr>
<tr>
<td valign="top" width="36">
<p><strong>22</strong></p>
</td>
<td valign="top" width="512">
<p>Auxiliar de limpeza</p>
</td>
<td valign="top" width="151">
<p align="center"><strong>R$ 2.143,22</strong></p>
</td>
</tr>
<tr>
<td valign="top" width="36">
<p><strong>23</strong></p>
</td>
<td valign="top" width="512">
<p>Mec&acirc;nico</p>
</td>
<td valign="top" width="151">
<p align="center"><strong>R$ 2.143,22</strong></p>
</td>
</tr>
<tr>
<td valign="top" width="36">
<p><strong>24</strong></p>
</td>
<td valign="top" width="512">
<p>Chapeador</p>
</td>
<td valign="top" width="151">
<p align="center"><strong>R$ 2.143,22</strong></p>
</td>
</tr>
<tr>
<td valign="top" width="36">
<p><strong>25</strong></p>
</td>
<td valign="top" width="512">
<p>Eletricista</p>
</td>
