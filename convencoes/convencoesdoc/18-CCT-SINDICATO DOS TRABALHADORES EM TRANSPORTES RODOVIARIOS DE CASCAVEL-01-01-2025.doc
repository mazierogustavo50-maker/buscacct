                                                        <label class="descricaoClausula" >
                                                            <p><a href="https://www3.mte.gov.br/sistemas/mediador/imagemAnexo/MR005340_20262026_02_20T15_17_13.pdf" target="_blank">Anexo (PDF)</a></p>
                                                        </label>
                                                        <br />
                                                        <label>
                                                            <b>
