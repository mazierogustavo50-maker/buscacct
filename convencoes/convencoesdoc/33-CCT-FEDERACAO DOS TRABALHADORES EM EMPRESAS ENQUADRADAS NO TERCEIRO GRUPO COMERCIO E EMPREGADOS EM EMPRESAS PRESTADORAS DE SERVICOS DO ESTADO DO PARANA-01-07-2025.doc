<script type="text/javascript">
        var recaptchaSiteKey = '6LdPnewrAAAAADM60VqWAyvhreJD6Jpyr1tORg6G';
        var pageLoadToken = '';
        var isPageValidated = false;

        function onRecaptchaLoad() {
            console.log('reCAPTCHA carregado, validando página...');
            executePageLoadRecaptcha();
        }

        function executePageLoadRecaptcha() {
            if (typeof grecaptcha === 'undefined') {
                console.error('reCAPTCHA não carregado');
                return;
            }

            grecaptcha.ready(function() {
                grecaptcha.execute(recaptchaSiteKey, {
                    action: 'page_load_resumo'
                }).then(function(token) {
                    console.log('Token de página gerado');
                    pageLoadToken = token;

                    // Enviar o token para o servidor
                    validatePageLoadToken(token);
                }).catch(function(error) {
                    console.error('Erro no reCAPTCHA de página:', error);
                    // Em desenvolvimento, permitir continuar
                });
            });
        }

        function validatePageLoadToken(token) {
            var currentUrl = window.location.href;
            var queryString = window.location.search;
            var nrSolicitacao = 'MR062941/2025';

            $.ajax({
                url: '/sistemas/mediador/Resumo/ValidateResumoPageLoad',
                type: 'POST',
                data: {
                    recaptchaToken: token,
                    currentUrl: currentUrl,
                    queryString: queryString,
                    nrSolicitacao: nrSolicitacao
                },
                success: function(response) {
                    if (response.success) {
                        console.log('Página validada com sucesso');
                        isPageValidated = true;
                        showPageContent();
                    } else {
                        console.warn('Validação de página falhou:', response.message);
                        handleValidationFailed(response);
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Erro ao validar página:', error);
                    handleValidationFailed({ message: 'Erro de comunicação com o servidor' });
                }
            });
        }

        function showPageContent() {
            // Remover overlay de loading se existir
            $('#recaptcha-loading').remove();
            console.log('Conteúdo da página liberado');
        }

        function handleValidationFailed(response) {
            // Mostrar mensagem de erro
            var errorHtml = `
                <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: white; z-index: 9999; display: flex; justify-content: center; align-items: center; flex-direction: column;">
                    <div style="text-align: center; padding: 20px;">
                        <h2 style="color: #d32f2f;">Validação de Segurança</h2>
                        <p style="font-size: 16px; margin: 20px 0;">${response.message || 'Falha na validação de segurança.'}</p>
                        <button onclick="window.location.reload()" style="padding: 10px 20px; background: #1976d2; color: white; border: none; border-radius: 4px; cursor: pointer;">
                            Tentar Novamente
                        </button>
                        <br><br>
                        <button onclick="window.location.href='/sistemas/mediador/'" style="padding: 8px 16px; background: #757575; color: white; border: none; border-radius: 4px; cursor: pointer;">
                            Voltar para Página Inicial
                        </button>
                    </div>
                </div>
            `;
            $('body').prepend(errorHtml);
        }

        $(document).ready(function() {
            console.log('Página carregada - ambiente de produção');

            // Pular validação reCAPTCHA em produção
            setTimeout(function() {
                if (!isPageValidated) {
                    console.log('Produção - validando sem reCAPTCHA');
                    isPageValidated = true;
                    showPageContent();
                }
            }, 1000);

            // Timeout de segurança reduzido
            setTimeout(function() {
                if (!isPageValidated) {
                    console.warn('Timeout na validação - liberando conteúdo');
                    isPageValidated = true;
                    showPageContent();
                }
            }, 5000); // Reduzido para 5 segundos
        });

        function Imprimir() {
            document.getElementById("btnResumoVisualizarImprimir").style.display = "none";
            document.getElementById("btnResumoVisualizarSalvar").style.display = "none";
            window.print();
            document.getElementById("btnResumoVisualizarImprimir").style.display = "";
            document.getElementById("btnResumoVisualizarSalvar").style.display = "";
            return true;
        }
        $(function () {
            var marcaDaguaHtml = $('.MarcaDagua').html();
            var width = $('body').width();
            var marcaW = $('.MarcaDagua').width();

            var qtdNescessarios = Math.round((width / marcaW) + 0.4);
            if (qtdNescessarios > 0)
                for (var incrementador = 0; incrementador < qtdNescessarios; incrementador++) {
                    $('.MarcaDagua').append("<br />");
                    $('.MarcaDagua').append(marcaDaguaHtml);
                }
        });


</script>
