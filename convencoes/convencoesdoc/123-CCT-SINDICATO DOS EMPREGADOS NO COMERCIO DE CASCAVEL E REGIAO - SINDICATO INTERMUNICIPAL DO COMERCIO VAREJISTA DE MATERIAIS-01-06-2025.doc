                                                                        ANEXO I - ATA ASSEMBLEIA SINDEC.2025
                                                                    </label>
                                                                </center>
                                                                <label class="tituloClausula">
                                                                                                                                    </label>
                                                            </b>
                                                        </label>
                                                        <b>
                                                            <label>

                                                            </label>
                                                        </b>
