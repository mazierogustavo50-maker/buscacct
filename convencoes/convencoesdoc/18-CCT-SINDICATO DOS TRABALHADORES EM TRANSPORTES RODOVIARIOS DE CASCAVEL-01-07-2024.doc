                                                            <p><a href="https://www3.mte.gov.br/sistemas/mediador/imagemAnexo/MR049112_20242024_09_18T08_26_06.pdf" target="_blank">Anexo (PDF)</a></p>
                                                        </label>
                                                        <br />
                                                        <label>
                                                            <b>
                                                                <center>
                                                                    <label class="textogrupo">
                                                                        ANEXO IV - ATA NEGOCIA&#199;&#195;O SITROVEL
                                                                    </label>
                                                                </center>
                                                                <label class="tituloClausula">
                                                                                                                                    </label>
                                                            </b>
                                                        </label>
                                                        <b>
                                                            <label>

                                                            </label>
                                                        </b>
