                                                                    <label class="textogrupo">
                                                                        ANEXO III - ATA DE NEGOCIA&#199;&#195;O SINTROPAB
                                                                    </label>
                                                                </center>
                                                                <label class="tituloClausula">
                                                                                                                                    </label>
