                                        <center>
                                            <label class="textogrupo">
                                                <b>ANEXOS </b>
                                            </label>
                                        </center>
                                                        <label>
                                                            <b>
                                                                <center>
                                                                    <label class="textogrupo">
                                                                        ANEXO I - ATA FETROPAR
                                                                    </label>
                                                                </center>
                                                                <label class="tituloClausula">
                                                                                                                                    </label>
                                                            </b>
                                                        </label>
                                                        <b>
                                                            <label>

                                                            </label>
                                                        </b>
